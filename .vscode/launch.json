{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "sweetpad-lldb",
      "request": "attach",
      "name": "Build & Run on iOS Simulator",
      "preLaunchTask": "sweetpad: debugging-launch"
    },
    {
      "type": "sweetpad-lldb",
      "request": "attach",
      "name": "Attach to Running App (SweetPad)",
      "preLaunchTask": "sweetpad: launch"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run Tests (Build Task Only)",
      "program": "${workspaceFolder}/.derivedData/Build/Products/Debug-iphonesimulator/MRR Project.app",
      "preLaunchTask": "test",
      "sourceMap": {
        "${workspaceFolder}": "${workspaceFolder}"
      }
    }
  ]
}
